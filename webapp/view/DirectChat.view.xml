<mvc:View
  controllerName="com.test.fsmchat.controller.DirectChat"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  displayBlock="true">

  <Page id="directChatPage" showHeader="false" class="fsmChatPage">
    <content>

      <!-- Header -->
      <VBox class="fsmChatHeaderBlock" width="100%">
        <HBox class="fsmChatHeaderRow" justifyContent="SpaceBetween" alignItems="Center" width="100%">
          <VBox class="fsmChatHeaderTitleBox">
            <Title text="{i18n>directChatTitle}" level="H2" class="fsmChatHeaderTitle" />
            <Text text="{i18n>directChatSubtitle}" class="fsmChatHeaderSub" />
          </VBox>
          <HBox alignItems="Center">
            <Button
              id="videoBtn"
              icon="sap-icon://video"
              type="Transparent"
              tooltip="{i18n>shareVideo}"
              visible="{= ${/videoSupported} &amp;&amp; ${/activeTab} === 'direct' &amp;&amp; !${/videoActive} }"
              press=".onStartVideo"
              class="fsmChatVideoBtn" />
            <Button
              id="videoEndBtn"
              icon="sap-icon://decline"
              type="Reject"
              tooltip="{i18n>endVideo}"
              visible="{= !!${/videoActive} }"
              press=".onEndVideo"
              class="fsmChatVideoBtn" />
            <ObjectStatus
              text="{context>/_connText}"
              state="{context>/_connState}"
              icon="{context>/_connIcon}"
              class="fsmChatConnStatus" />
          </HBox>
        </HBox>
      </VBox>

      <!-- Tabs -->
      <IconTabBar id="directTabBar" select=".onTabSelect" class="fsmDirectTabBar" expanded="true">
        <items>
          <!-- Unread count shown as badge; clears when tab is opened -->
          <IconTabFilter key="broadcasts" text="{i18n>directTabBroadcasts}"
            icon="sap-icon://megaphone"
            count="{= ${/unreadCount} > 0 ? ${/unreadCount} + '' : '' }" />
          <IconTabFilter key="direct" text="{i18n>directTabDirect}" icon="sap-icon://discussion" />
        </items>
        <content>

          <!-- ── Broadcasts tab ── -->
          <VBox id="tabBroadcasts"
            visible="{= ${/activeTab} === 'broadcasts' }"
            class="fsmDirectTabContent">

            <VBox visible="{= ${/broadcasts}.length === 0 }" alignItems="Center" class="fsmChatEmptyState">
              <core:Icon src="sap-icon://megaphone" class="fsmChatEmptyIcon" />
              <Text text="{i18n>directNoBroadcasts}" class="fsmChatEmptyText" />
            </VBox>

            <HBox
              visible="{= ${/broadcasts}.length > 0 }"
              justifyContent="End"
              class="fsmDirectClearRow">
              <Button
                text="{i18n>broadcastClearAll}"
                icon="sap-icon://delete"
                type="Transparent"
                press=".onClearBroadcasts"
                class="fsmDirectClearBtn" />
            </HBox>

            <List
              visible="{= ${/broadcasts}.length > 0 }"
              items="{ path: '/broadcasts', templateShareable: false }"
              showSeparators="Inner"
              class="fsmDirectBroadcastList">
              <CustomListItem class="{= ${read} ? 'fsmDirectBroadcastItemRead' : 'fsmDirectBroadcastItemUnread' }">
                <HBox alignItems="Start" width="100%" class="fsmDirectBroadcastMsg">
                  <!-- Unread dot -->
                  <core:Icon
                    src="sap-icon://circle-task-2"
                    visible="{= !${read} }"
                    class="fsmDirectUnreadDot" />
                  <VBox class="fsmDirectBroadcastBody">
                    <HBox alignItems="Center" class="fsmDirectBroadcastHead">
                      <core:Icon src="sap-icon://megaphone" class="fsmDirectBroadcastIcon" />
                      <Text text="{senderName}" class="fsmChatInboxName" />
                      <Text text="{ts}" class="fsmDirectBroadcastTime" />
                    </HBox>
                    <Text text="{text}" class="fsmDirectBroadcastText" />
                  </VBox>
                </HBox>
              </CustomListItem>
            </List>
          </VBox>

          <!-- ── Direct chat tab ── -->
          <!-- Direct chat tab -->
          <VBox id="tabDirect" visible="{= ${/activeTab} === 'direct' }" class="fsmDirectTabContent">

            <!-- Video panel -->
            <VBox visible="{= !!${/videoActive} }" class="fsmChatVideoPanel" width="100%">
              <HBox class="fsmChatVideoStatusRow" alignItems="Center" justifyContent="SpaceBetween">
                <Text text="{= 'Video · ' + ${/videoStatusText} }" class="fsmChatVideoStatus" />
                <Button icon="sap-icon://decline" type="Reject" text="{i18n>endVideo}" press=".onEndVideo" class="fsmChatVideoEndInline" />
              </HBox>
              <core:HTML content="&lt;video id=&quot;directRemoteVideo&quot; autoplay playsinline class=&quot;fsmChatRemoteVideo&quot;&gt;&lt;/video&gt;" />
              <core:HTML content="&lt;video id=&quot;directLocalVideo&quot; autoplay playsinline muted class=&quot;fsmChatLocalVideo&quot;&gt;&lt;/video&gt;" />
            </VBox>

            <!-- Incoming call -->
            <HBox visible="{= !!${/incomingCall} }" class="fsmChatIncomingCall" alignItems="Center" justifyContent="SpaceBetween">
              <Text text="{i18n>incomingVideo}" class="fsmChatIncomingText" />
              <HBox>
                <Button text="{i18n>acceptVideo}" type="Accept" icon="sap-icon://video" press=".onAcceptVideo" />
                <Button text="{i18n>declineVideo}" type="Reject" icon="sap-icon://decline" press=".onDeclineVideo" />
              </HBox>
            </HBox>

            <VBox visible="{= ${/directMessages}.length === 0 }" alignItems="Center" class="fsmChatEmptyState">
              <core:Icon src="sap-icon://discussion" class="fsmChatEmptyIcon" />
              <Text text="{i18n>directNoMessages}" class="fsmChatEmptyText" />
            </VBox>

            <VBox id="directMsgScroll" class="fsmChatScroll" width="100%">
              <VBox id="directMsgContainer" class="fsmChatMsgContainer" width="100%">
                <List items="{ path: '/directMessages', templateShareable: false }" showSeparators="None" class="fsmChatList">
                  <CustomListItem class="fsmChatMsgItem">
                    <VBox class="{= ${mine} === 'mine' ? 'fsmChatBubbleWrap fsmChatBubbleWrapMine' : 'fsmChatBubbleWrap' }">
                      <Text text="{= ${senderRole} ? ${senderName} + ' · ' + ${senderRole} : ${senderName} }" class="fsmChatSender" />
                      <VBox class="{= ${mine} === 'mine' ? 'fsmChatBubble fsmChatBubbleMine' : 'fsmChatBubble fsmChatBubbleTheirs' }">
                        <Text text="{text}" class="fsmChatMsgText" />
                        <Text text="{time}" class="fsmChatMsgTime" />
                      </VBox>
                    </VBox>
                  </CustomListItem>
                </List>
              </VBox>
            </VBox>
          </VBox>

        </content>
      </IconTabBar>

    </content>

    <footer>
      <Bar visible="{= ${/activeTab} === 'direct' }" class="fsmChatInputBar">
        <contentMiddle>
          <Input id="directInput" width="100%" placeholder="{i18n>inputPlaceholder}"
            value="{/directDraft}" submit=".onDirectSend" class="fsmChatInput" />
        </contentMiddle>
        <contentRight>
          <Button icon="sap-icon://paper-plane" type="Emphasized"
            enabled="{= !!${/directDraft} &amp;&amp; ${/directDraft}.trim().length > 0 }"
            press=".onDirectSend" class="fsmChatSendBtn" />
        </contentRight>
      </Bar>
    </footer>
  </Page>
</mvc:View>
