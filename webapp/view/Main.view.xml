<mvc:View
  controllerName="com.test.fsmchat.controller.Main"
  xmlns="sap.m"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns:core="sap.ui.core"
  xmlns:f="sap.f"
  height="100%">

  <Page
    id="chatPage"
    showHeader="false"
    class="fsmChatPage">

    <content>

      <!-- ============ HEADER (in content flow, not a fixed-height Bar) ======
           The FSM mobile webview clips a fixed-height customHeader Bar, hiding
           the title/subtitle/status. Rendering the header as a normal content
           block lets it size to its content so everything stays visible. -->
      <VBox class="fsmChatHeaderBlock" width="100%">
        <HBox class="fsmChatHeaderRow" justifyContent="SpaceBetween" alignItems="Center" width="100%">
          <HBox class="fsmChatHeaderLeft" alignItems="Center">
            <core:Icon src="sap-icon://discussion" class="fsmChatHeaderIcon" />
            <VBox class="fsmChatHeaderTitleBox">
              <Title text="{i18n>chatTitle}" level="H2" class="fsmChatHeaderTitle" />
              <!-- Line 1: who you're talking to + (technician only) live status. -->
              <HBox alignItems="Center" class="fsmChatHeaderStatusRow" visible="{= !!${context>/_bound} }">
                <core:Icon
                  src="{= ${/isTechnician} ? (${/dispatcherPresent} ? 'sap-icon://connected' : 'sap-icon://pending') : (${/technicianPresent} ? 'sap-icon://connected' : 'sap-icon://disconnected') }"
                  class="fsmChatHeaderStatusIcon {= ${/isTechnician} ? (${/dispatcherPresent} ? 'fsmStatLive' : 'fsmStatWait') : (${/technicianPresent} ? 'fsmStatLive' : 'fsmStatOff') }" />
                <Text
                  class="fsmChatHeaderSub"
                  text="{= ${/isTechnician} ? (${/dispatcherPresent} ? ${i18n>techDispConnected} : ${i18n>techWaiting}) : ((${/technicianPresent} ? ${i18n>dispTechOnline} : ${i18n>dispTechOffline}) + (${/peerName} ? ' \u00b7 ' + ${/peerName} : '')) }" />
              </HBox>
              <!-- Line 2: activity id, shown ONCE here (no duplicate banner below). -->
              <Text
                class="fsmChatHeaderActivity"
                visible="{= !!${context>/_bound} }"
                text="{= ${i18n>activityLabel} + ' ' + ${/activityCode} }" />
              <!-- Unbound: dispatcher sees the inbox label; others see role. -->
              <Text
                class="fsmChatHeaderSub"
                visible="{= !${context>/_bound} }"
                text="{= ${/isDispatcher} ? ${i18n>dispInboxLabel} : ${context>/_peerLabel} }" />
            </VBox>
          </HBox>
          <HBox class="fsmChatHeaderRight" alignItems="Center">
            <Button
              id="directChatNavBtn"
              icon="sap-icon://discussion"
              type="Transparent"
              tooltip="{i18n>directChatNavTip}"
              visible="{= !!${/isTechnician} }"
              press=".onNavToDirectChat"
              class="fsmChatVideoBtn" />
            <Button
              id="videoBtn"
              icon="sap-icon://video"
              type="Transparent"
              tooltip="{i18n>shareVideo}"
              visible="{= !!${context>/_bound} &amp;&amp; ${/videoSupported} &amp;&amp; ${context>/role} === 'technician' &amp;&amp; !${/videoActive} }"
              press=".onStartVideo"
              class="fsmChatVideoBtn" />
            <Button
              id="directChatBtn"
              icon="sap-icon://discussion-2"
              type="Transparent"
              tooltip="{i18n>directChatNavBtn}"
              visible="{= ${context>/role} === 'technician' }"
              press=".onNavToDirectChat"
              class="fsmChatVideoBtn" />
            <Button
              id="videoEndBtn"
              icon="sap-icon://decline"
              type="Reject"
              tooltip="{i18n>endVideo}"
              visible="{= !!${/videoActive} }"
              press=".onEndVideo"
              class="fsmChatVideoBtn" />
            <Button
              id="leaveActivityBtn"
              icon="sap-icon://inbox"
              text="{i18n>leaveActivity}"
              type="Transparent"
              tooltip="{i18n>leaveActivityTip}"
              visible="{= !!${context>/_bound} &amp;&amp; ${context>/role} === 'dispatcher' }"
              press=".onLeaveActivity"
              class="fsmChatLeaveBtn" />
            <ObjectStatus
              id="connStatus"
              text="{context>/_connText}"
              state="{context>/_connState}"
              icon="{context>/_connIcon}"
              class="fsmChatConnStatus" />
          </HBox>
        </HBox>
      </VBox>

      <!-- ============ UNBOUND STATE: no activity selected yet ============ -->
      <VBox
        id="bindPanel"
        visible="{= !${context>/_bound} }"
        class="fsmChatBindPanel"
        alignItems="Center">

        <!-- Non-dispatcher (technician/tester): manual activity-ID entry. -->
        <VBox
          visible="{= !${/isDispatcher} }"
          alignItems="Center"
          width="100%">
          <core:Icon src="sap-icon://activity-items" class="fsmChatBindIcon" />
          <Title text="{i18n>bindTitle}" level="H3" class="fsmChatBindTitle" />
          <Text
            text="{= ${context>/_shellReady} ? ${i18n>bindHintShell} : ${i18n>bindHint} }"
            class="fsmChatBindHint"
            textAlign="Center" />
          <HBox class="fsmChatBindRow" alignItems="Center">
            <Input
              id="manualIdInput"
              width="14rem"
              placeholder="{i18n>bindPlaceholder}"
              value="{/manualId}"
              submit=".onBindManual"
              class="fsmChatBindInput" />
            <Button
              text="{i18n>bindButton}"
              type="Emphasized"
              enabled="{= !!${/manualId} &amp;&amp; ${/manualId}.trim().length > 0 }"
              press=".onBindManual"
              class="fsmChatBindBtn" />
          </HBox>
        </VBox>

        <!-- Dispatcher: inbox-oriented heading (no manual entry). -->
        <VBox
          visible="{= !!${/isDispatcher} }"
          alignItems="Center"
          width="100%">
          <core:Icon src="sap-icon://inbox" class="fsmChatBindIcon" />
          <Title text="{i18n>dispWaitTitle}" level="H3" class="fsmChatBindTitle" />
          <Text
            text="{= ${/unattendedCount} > 0 ? ${i18n>dispWaitHasItems} : ${i18n>dispWaitEmpty} }"
            class="fsmChatBindHint"
            textAlign="Center" />
        </VBox>

        <!-- ===== Inline FSM API test (dispatcher, ?apitest=1) ===== -->
        <VBox
          visible="{= !!${/apiTest} }"
          class="fsmChatInbox"
          width="100%">
          <Title text="FSM Data API test" level="H3" class="fsmChatInboxTitle" />
          <Text text="Uses the live shell token. Read the 'verdict' line in the result." class="fsmChatInboxHint" />
          <HBox wrap="Wrap" class="fsmChatBindRow">
            <Button text="Persons (plannable)" type="Emphasized" press=".onApiTestPersons" class="fsmChatInboxPickBtn" />
            <Button text="Regions" press=".onApiTestRegions" class="fsmChatInboxPickBtn" />
            <Button text="CoreSQL Query" press=".onApiTestQuery" class="fsmChatInboxPickBtn" />
          </HBox>
          <TextArea
            value="{/apiTestOut}"
            editable="false"
            growing="false"
            rows="12"
            width="100%"
            class="fsmChatDebugLog" />
        </VBox>

        <!-- ===== Dispatcher broadcast panel ===== -->
        <VBox
          visible="{= !!${/isDispatcher} }"
          class="fsmChatInbox"
          width="100%">
          <HBox alignItems="Center" class="fsmChatInboxHead">
            <core:Icon src="sap-icon://send" class="fsmChatInboxIcon" />
            <Title text="{i18n>broadcastTitle}" level="H3" class="fsmChatInboxTitle" />
          </HBox>
          <Text text="{i18n>broadcastHint}" class="fsmChatInboxHint" />

          <!-- Load roster button (shown until loaded) -->
          <Button
            visible="{= !${/rosterLoaded} &amp;&amp; !${/rosterLoading} }"
            text="{i18n>broadcastLoadRoster}"
            type="Emphasized"
            icon="sap-icon://synchronize"
            press=".onLoadRoster"
            class="fsmChatInboxPickBtn" />
          <Text
            visible="{= !!${/rosterLoading} }"
            text="{i18n>broadcastLoading}"
            class="fsmChatInboxHint" />

          <!-- Mode selector (shown once roster is loaded) -->
          <VBox visible="{= !!${/rosterLoaded} }" width="100%">
            <SegmentedButton
              id="broadcastModeBar"
              selectionChange=".onBroadcastModeChange"
              width="100%"
              class="fsmChatBroadcastTabs">
              <items>
                <SegmentedButtonItem key="all" text="{i18n>broadcastModeAll}" icon="sap-icon://group" />
                <SegmentedButtonItem key="region" text="{i18n>broadcastModeRegion}" icon="sap-icon://map" />
                <SegmentedButtonItem key="individual" text="{i18n>broadcastModeIndividual}" icon="sap-icon://employee" />
              </items>
            </SegmentedButton>

            <!-- Region picker (mode=region) -->
            <Select
              id="broadcastRegionSelect"
              visible="{= ${/broadcastMode} === 'region' }"
              width="100%"
              forceSelection="false"
              change=".onBroadcastRegionChange"
              class="fsmChatBroadcastSelect">
              <items>
                <core:ListItem key="" text="{i18n>broadcastRegionPlaceholder}" />
              </items>
            </Select>
            <!-- Region technician preview: pre-filtered by controller into /regionTechs -->
            <List
              visible="{= ${/broadcastMode} === 'region' &amp;&amp; !!${/broadcastRegion} }"
              items="{ path: '/regionTechs', templateShareable: false }"
              showSeparators="None"
              class="fsmChatBroadcastPreview">
              <CustomListItem class="fsmChatBroadcastPreviewItem">
                <Text text="{label}" class="fsmChatInboxName" />
              </CustomListItem>
            </List>

            <!-- Individual picker (mode=individual) -->
            <Input
              visible="{= ${/broadcastMode} === 'individual' }"
              value="{/broadcastSearch}"
              placeholder="{i18n>broadcastSearchPlaceholder}"
              liveChange=".onBroadcastSearch"
              width="100%"
              class="fsmChatBroadcastSearchInput" />
            <List
              id="broadcastTargetList"
              visible="{= ${/broadcastMode} === 'individual' }"
              items="{ path: '/broadcastTargets', templateShareable: false }"
              mode="MultiSelect"
              selectionChange=".onBroadcastTargetToggle"
              showSeparators="Inner"
              class="fsmChatBroadcastList">
              <StandardListItem
                title="{= ${firstName} + ' ' + ${lastName} }"
                description="{userName}"
                selected="{selected}"
                class="fsmChatBroadcastItem" />
            </List>

            <!-- Message input + send -->
            <TextArea
              value="{/broadcastDraft}"
              placeholder="{i18n>broadcastDraftPlaceholder}"
              rows="3"
              width="100%"
              class="fsmChatBroadcastInput" />
            <Button
              text="{i18n>broadcastSendBtn}"
              type="Emphasized"
              icon="sap-icon://paper-plane"
              enabled="{= !!${/broadcastDraft} &amp;&amp; ${/broadcastDraft}.trim().length > 0 }"
              press=".onBroadcastSend"
              class="fsmChatInboxPickBtn" />
          </VBox>
        </VBox>

        <!-- ===== Dispatcher inbox: unattended conversations ===== -->
        <VBox
          visible="{= !!${/isDispatcher} &amp;&amp; ${/unattendedCount} > 0 }"
          class="fsmChatInbox"
          width="100%">
          <HBox class="fsmChatInboxHead" alignItems="Center">
            <core:Icon src="sap-icon://inbox" class="fsmChatInboxIcon" />
            <Title
              text="{= ${i18n>inboxTitle} + ' (' + ${/unattendedCount} + ')' }"
              level="H3"
              class="fsmChatInboxTitle" />
          </HBox>
          <Text text="{i18n>inboxHint}" class="fsmChatInboxHint" />
          <List
            items="{ path: '/unattended', templateShareable: false }"
            showSeparators="Inner"
            class="fsmChatInboxList">
            <CustomListItem class="fsmChatInboxItem">
              <HBox justifyContent="SpaceBetween" alignItems="Center" width="100%" class="fsmChatInboxRow">
                <VBox class="fsmChatInboxRowText">
                  <Text
                    text="{= (${lastName} || ${i18n>roleTechnician}) + ' \u00b7 ' + ${i18n>roleTechnician} }"
                    class="fsmChatInboxName" />
                  <Text text="{lastText}" maxLines="1" class="fsmChatInboxPreview" />
                  <Text text="{= ${i18n>activityLabel} + ' ' + ${activityId} }" maxLines="1" class="fsmChatInboxActivity" />
                </VBox>
                <VBox alignItems="End" class="fsmChatInboxRowAction">
                  <ObjectStatus
                    text="{= ${count} > 1 ? ${count} + ' ' + ${i18n>inboxMsgs} : '1 ' + ${i18n>inboxMsg} }"
                    state="Information"
                    class="fsmChatInboxCount" />
                  <Button
                    text="{i18n>inboxPickUp}"
                    type="Emphasized"
                    icon="sap-icon://begin"
                    press=".onPickUp"
                    class="fsmChatInboxPickBtn" />
                </VBox>
              </HBox>
            </CustomListItem>
          </List>
        </VBox>

        <!-- DEBUG: shows raw Shell messages when launched with &debug=1 -->
        <VBox
          visible="{= !!${context>/_debug} }"
          class="fsmChatDebugBox"
          width="100%">
          <Text text="{i18n>debugHeader}" class="fsmChatDebugTitle" />
          <TextArea
            value="{context>/_debugLog}"
            editable="false"
            growing="false"
            rows="10"
            width="100%"
            class="fsmChatDebugLog" />
        </VBox>
      </VBox>

      <!-- ============ BOUND STATE: the chat ============
           Plain VBox (page scrolls as one unit) so the sticky header stays
           frozen at the top while a long conversation scrolls beneath it. -->
      <VBox
        id="msgScroll"
        width="100%"
        visible="{= !!${context>/_bound} }"
        class="fsmChatScroll">

        <VBox id="msgContainer" class="fsmChatMsgContainer" width="100%">

          <!-- Technician: broadcast messages received from dispatchers -->
          <VBox
            visible="{= !!${/isTechnician} &amp;&amp; ${/broadcasts}.length > 0 }"
            class="fsmChatInbox"
            width="100%">
            <HBox alignItems="Center" class="fsmChatInboxHead">
              <core:Icon src="sap-icon://megaphone" class="fsmChatInboxIcon" />
              <Title text="{i18n>broadcastReceivedTitle}" level="H3" class="fsmChatInboxTitle" />
            </HBox>
            <Text text="{i18n>broadcastReceivedHint}" class="fsmChatInboxHint" />
            <List
              items="{ path: '/broadcasts', templateShareable: false }"
              showSeparators="Inner"
              class="fsmChatInboxList">
              <CustomListItem class="fsmChatInboxItem">
                <VBox class="fsmChatBroadcastMsg">
                  <Text text="{text}" class="fsmChatMsgText" />
                  <HBox>
                    <Text text="{senderName}" class="fsmChatInboxName" />
                    <Text text=" · " class="fsmChatInboxActivity" />
                    <Text text="{ts}" class="fsmChatInboxActivity" />
                  </HBox>
                </VBox>
              </CustomListItem>
            </List>
          </VBox>

          <!-- Video panel (visible during a call) -->
          <VBox
            visible="{= !!${/videoActive} }"
            class="fsmChatVideoPanel"
            width="100%">
            <HBox class="fsmChatVideoStatusRow" alignItems="Center" justifyContent="SpaceBetween">
              <Text text="{= ${i18n>videoLabel} + ' \u00b7 ' + ${/videoStatusText} }" class="fsmChatVideoStatus" />
              <Button icon="sap-icon://decline" type="Reject" text="{i18n>endVideo}" press=".onEndVideo" class="fsmChatVideoEndInline" />
            </HBox>
            <!-- Dispatcher sees the incoming (remote) stream; technician sees
                 their own local preview. Both elements exist; the relevant one
                 gets a stream attached by the controller. -->
            <core:HTML content="&lt;video id=&quot;remoteVideo&quot; autoplay playsinline class=&quot;fsmChatRemoteVideo&quot;&gt;&lt;/video&gt;"
              visible="{= ${context>/role} !== 'technician' }" />
            <core:HTML content="&lt;video id=&quot;localVideo&quot; autoplay playsinline muted class=&quot;fsmChatLocalVideo&quot;&gt;&lt;/video&gt;"
              visible="{= ${context>/role} === 'technician' }" />
          </VBox>

          <!-- Incoming call prompt (dispatcher) -->
          <VBox
            visible="{= !!${/incomingCall} }"
            class="fsmChatIncoming"
            alignItems="Center">
            <Text text="{i18n>incomingVideo}" class="fsmChatIncomingText" />
            <HBox class="fsmChatIncomingBtns">
              <Button text="{i18n>acceptVideo}" type="Accept" icon="sap-icon://video" press=".onAcceptVideo" />
              <Button text="{i18n>declineVideo}" type="Reject" icon="sap-icon://decline" press=".onDeclineVideo" />
            </HBox>
          </VBox>

          <!-- Empty thread -->
          <VBox
            id="emptyState"
            visible="{= ${/messages}.length === 0 }"
            class="fsmChatEmpty"
            alignItems="Center"
            justifyContent="Center">
            <core:Icon src="sap-icon://comment" class="fsmChatEmptyIcon" />
            <Text text="{i18n>emptyState}" class="fsmChatEmptyText" textAlign="Center" />
          </VBox>

          <!-- Messages -->
          <List
            id="messageList"
            items="{
              path: '/messages',
              templateShareable: false
            }"
            showSeparators="None"
            backgroundDesign="Transparent"
            showNoData="false"
            class="fsmChatList">
            <CustomListItem class="fsmChatItem">
              <FlexBox
                direction="Column"
                class="fsmChatBubbleWrap {mine}"
                alignItems="{= ${mine} === 'mine' ? 'End' : 'Start' }">
                <VBox class="fsmChatBubble {mine}">
                  <Text
                    text="{= ${senderRole} ? ${senderName} + ' \u00b7 ' + ${senderRole} : ${senderName} }"
                    visible="{= ${mine} !== 'mine' }"
                    class="fsmChatSender" />
                  <Text text="{text}" class="fsmChatText" />
                  <Text text="{time}" class="fsmChatTime" textAlign="End" />
                </VBox>
              </FlexBox>
            </CustomListItem>
          </List>

          <!-- Typing indicator -->
          <HBox
            id="typingBox"
            visible="{/peerTyping}"
            class="fsmChatTyping"
            alignItems="Center">
            <Text text="{context>/_peerName} {i18n>typing}" class="fsmChatTypingText" />
          </HBox>

        </VBox>
      </VBox>
    </content>

    <footer>
      <Toolbar class="fsmChatFooter" visible="{= !!${context>/_bound} }">
        <TextArea
          id="msgInput"
          width="100%"
          rows="1"
          growing="true"
          growingMaxLines="4"
          placeholder="{i18n>inputPlaceholder}"
          value="{/draft}"
          liveChange=".onTyping"
          class="fsmChatInput" />
        <Button
          id="sendBtn"
          icon="sap-icon://paper-plane"
          type="Emphasized"
          tooltip="{i18n>send}"
          enabled="{= !!${/draft} &amp;&amp; ${/draft}.trim().length > 0 }"
          press=".onSend"
          class="fsmChatSendBtn" />
      </Toolbar>
    </footer>

  </Page>
</mvc:View>
