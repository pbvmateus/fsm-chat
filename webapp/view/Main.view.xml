<mvc:View
  controllerName="com.test.fsmchat.controller.Main"
  xmlns="sap.m"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns:core="sap.ui.core"
  xmlns:f="sap.f"
  height="100%">

  <Page
    id="chatPage"
    showHeader="true"
    class="fsmChatPage">

    <customHeader>
      <Bar class="fsmChatHeaderBar">
        <contentLeft>
          <core:Icon src="sap-icon://discussion" class="fsmChatHeaderIcon" />
          <VBox class="fsmChatHeaderTitleBox">
            <Title text="{i18n>chatTitle}" level="H2" class="fsmChatHeaderTitle" />
            <Text text="{context>/_peerLabel}" class="fsmChatHeaderSub" />
          </VBox>
        </contentLeft>
        <contentRight>
          <ObjectStatus
            id="connStatus"
            text="{context>/_connText}"
            state="{context>/_connState}"
            icon="{context>/_connIcon}"
            class="fsmChatConnStatus" />
        </contentRight>
      </Bar>
    </customHeader>

    <content>
      <ScrollContainer
        id="msgScroll"
        height="100%"
        width="100%"
        vertical="true"
        focusable="false"
        class="fsmChatScroll">

        <VBox id="msgContainer" class="fsmChatMsgContainer" width="100%">

          <!-- Empty state -->
          <VBox
            id="emptyState"
            visible="{= ${/messages}.length === 0 }"
            class="fsmChatEmpty"
            alignItems="Center"
            justifyContent="Center">
            <core:Icon src="sap-icon://comment" class="fsmChatEmptyIcon" />
            <Text text="{i18n>emptyState}" class="fsmChatEmptyText" textAlign="Center" />
          </VBox>

          <!-- Messages -->
          <List
            id="messageList"
            items="{
              path: '/messages',
              templateShareable: false
            }"
            showSeparators="None"
            backgroundDesign="Transparent"
            class="fsmChatList">
            <CustomListItem class="fsmChatItem">
              <FlexBox
                direction="Column"
                class="fsmChatBubbleWrap {mine}"
                alignItems="{= ${mine} === 'mine' ? 'End' : 'Start' }">
                <VBox class="fsmChatBubble {mine}">
                  <Text
                    text="{senderName}"
                    visible="{= ${mine} !== 'mine' }"
                    class="fsmChatSender" />
                  <Text text="{text}" class="fsmChatText" />
                  <Text text="{time}" class="fsmChatTime" textAlign="End" />
                </VBox>
              </FlexBox>
            </CustomListItem>
          </List>

          <!-- Typing indicator -->
          <HBox
            id="typingBox"
            visible="{/peerTyping}"
            class="fsmChatTyping"
            alignItems="Center">
            <Text text="{context>/_peerName} {i18n>typing}" class="fsmChatTypingText" />
          </HBox>

        </VBox>
      </ScrollContainer>
    </content>

    <footer>
      <Toolbar class="fsmChatFooter">
        <TextArea
          id="msgInput"
          width="100%"
          rows="1"
          growing="true"
          growingMaxLines="4"
          placeholder="{i18n>inputPlaceholder}"
          value="{/draft}"
          liveChange=".onTyping"
          class="fsmChatInput" />
        <Button
          id="sendBtn"
          icon="sap-icon://paper-plane"
          type="Emphasized"
          tooltip="{i18n>send}"
          enabled="{= !!${/draft} &amp;&amp; ${/draft}.trim().length > 0 }"
          press=".onSend"
          class="fsmChatSendBtn" />
      </Toolbar>
    </footer>

  </Page>
</mvc:View>
