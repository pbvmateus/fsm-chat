{
  "_version": "1.40.0",
  "sap.app": {
    "id": "com.test.fsmchat",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "dataSources": {},
    "crossNavigation": {
      "inbounds": {
        "fsmchat-display": {
          "semanticObject": "FSMChat",
          "action": "display",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "sap-icon://discussion",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    },
    "supportedThemes": [
      "sap_horizon",
      "sap_fiori_3",
      "sap_belize"
    ]
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "com.test.fsmchat.view.App",
      "type": "XML",
      "id": "app",
      "async": true
    },
    "dependencies": {
      "minUI5Version": "1.71.0",
      "libs": {
        "sap.ui.core": {},
        "sap.m": {},
        "sap.f": {},
        "sap.ui.layout": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.test.fsmchat.i18n.i18n"
        }
      },
      "": {
        "type": "sap.ui.model.json.JSONModel"
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "com.test.fsmchat.view",
        "controlId": "app",
        "controlAggregation": "pages",
        "async": true
      },
      "routes": [
        {
          "name": "main",
          "pattern": "",
          "target": "main"
        }
      ],
      "targets": {
        "main": {
          "viewId": "main",
          "viewName": "Main"
        }
      }
    }
  },
  "sap.fsm": {
    "extension": {
      "type": "ScreenExtension",
      "supportedClients": ["MOBILE", "SHELL"],
      "objectType": "ServiceCall",
      "title": "{{appTitle}}",
      "shortTitle": "Chat",
      "subTitle": "{{appDescription}}",
      "icon": "sap-icon://discussion"
    }
  }
}
